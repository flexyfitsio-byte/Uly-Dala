datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  fullName       String
  createdAt      DateTime        @default(now())
  xp             Int             @default(0)
  level          String          @default("Новичок")
  trips          Trip[]
  passportStamps PassportStamp[]
}

model Place {
  id          String   @id @default(uuid())
  name        String   @unique
  region      String
  description String   @db.Text
  history     String   @db.Text
  latitude    Float
  longitude   Float
  avgCost     Int
  category    String
  createdAt   DateTime @default(now())
  quizzes     Quiz[]
}

model Trip {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query      String
  budget     Int
  daysCount  Int
  routeJson  Json
  createdAt  DateTime @default(now())
}

model PassportStamp {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeName String
  visitedAt DateTime @default(now())
}

model Quiz {
  id            String   @id @default(uuid())
  placeId       String
  place         Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  question      String
  options       String[]
  correctAnswer String
  xpReward      Int      @default(50)
}
